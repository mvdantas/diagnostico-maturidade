# Supabase
# Backend only. Never expose SUPABASE_SERVICE_ROLE_KEY in index.html or browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Lead attribution defaults
LEADS_SOURCE=diagnostico-maturidade-digital
LEADS_CAMPAIGN=onda-01-ia-saude

# LGPD consent metadata
LEAD_CONSENT_VERSION=2026-06-28
PRIVACY_POLICY_URL=

# Runtime
APP_ENV=production

# Future optional integrations. Not used in Etapa 1.
# HubSpot variables are optional and reserved for a future integration.
HUBSPOT_ENABLED=false
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# Resend variables are optional and reserved for a future integration.
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM=
